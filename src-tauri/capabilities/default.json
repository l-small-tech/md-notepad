{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Capabilities for the main window. Custom commands in src/commands/ need no entries here — only core/plugin permissions do.",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "core:window:allow-set-title",
    "core:window:allow-close",
    "core:window:allow-destroy",
    "dialog:default",
    "store:default",
    "updater:default",
    "process:allow-restart",
    "opener:default",
    "log:default",
    "window-state:default"
  ]
}
