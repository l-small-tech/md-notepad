# Node
node_modules/
dist/

# Rust / Tauri
src-tauri/target/
src-tauri/gen/schemas/

# Android / Gradle build output (regenerated by `tauri android` / Gradle —
# tracking it left the tree perpetually dirty after every build)
src-tauri/plugins/*/android/build/
src-tauri/plugins/*/android/.gradle/
src-tauri/plugins/*/android/.tauri/

# Android signing material — never commit
*.jks
*.keystore
keystore.properties

# Local-only files
*.local
*.log

# OS cruft
.DS_Store
Thumbs.db


# AI Guidance
CLAUDE.md
AGENT_LOCKS.md
guidance/*
guidance/